menu "Musopti Display"
    config MUSOPTI_DISPLAY_SIMULATED
        bool "Use simulated display (log only, no LVGL)"
        default y
        help
            When enabled, the display module logs state updates instead of
            driving the SH8601 AMOLED panel.  Disable when building for
            the real board with the 368x448 screen.
endmenu
